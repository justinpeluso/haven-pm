# Database
DATABASE_URL="postgresql://haven:haven_dev_password@localhost:5432/haven_pm?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# File uploads (local dev)
UPLOAD_DIR="./uploads"

# External payment portal (tenant "Pay Rent" button — external mode)
PAYMENT_PORTAL_URL="https://payments.example.com"

# External SMS / messaging portal (Messages → Open SMS Portal)
# Default: OpenPhone web inbox — https://www.openphone.com/
MESSAGING_PORTAL_URL="https://my.quo.com/"
MESSAGING_PROVIDER_NAME="OpenPhone"
MESSAGING_PHONE_NUMBER="(412) 797-5007"

# Stripe (optional — enable in Settings)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# OpenAI — enables Downtown Computer Helper live AI (+ DuckDuckGo research).
# Without this, Computer Helper still returns a labeled offline playbook (never blank).
# Production: set OPENAI_API_KEY in the Vercel project → Settings → Environment Variables
# (Production + Preview), then redeploy. Also used by Neverworld DM.
OPENAI_API_KEY=""
# OPENAI_DM_MODEL="gpt-4o-mini"
# OPENAI_COMPUTER_HELPER_MODEL="gpt-4o-mini"
