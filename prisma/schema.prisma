// Haven PM - Property Management Platform
// Normalized relational schema with audit trails and soft deletes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMINISTRATOR
  PROPERTY_MANAGER
  LEASING_AGENT
  MAINTENANCE_STAFF
  OFFICE_STAFF
  TENANT
  PROSPECT
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  UNDER_RENOVATION
  FOR_SALE
}

enum UnitStatus {
  AVAILABLE
  OCCUPIED
  NOTICE_GIVEN
  VACANT
  MAINTENANCE_HOLD
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
}

enum ChargeType {
  RENT
  LATE_FEE
  SECURITY_DEPOSIT
  OTHER
}

enum ChargeStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  CHECK
  ACH
  CARD
  STRIPE
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  VOIDED
}

enum MaintenanceStatus {
  SUBMITTED
  ASSIGNED
  SCHEDULED
  IN_PROGRESS
  WAITING_ON_PARTS
  COMPLETED
  CLOSED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  APPLIANCE
  STRUCTURAL
  PEST_CONTROL
  LANDSCAPING
  GENERAL
  OTHER
}

enum ProspectStatus {
  NEW
  CONTACTED
  SHOWING_SCHEDULED
  APPLICATION_SENT
  APPLICATION_RECEIVED
  APPROVED
  DENIED
  LEASED
  ARCHIVED
}

enum ShowingStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum CalendarEventType {
  SHOWING
  MAINTENANCE
  INSPECTION
  MOVE_IN
  MOVE_OUT
  STAFF_EVENT
  OTHER
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum DocumentType {
  LEASE
  INSPECTION_REPORT
  NOTICE
  MOVE_IN_CHECKLIST
  SIGNED_DOCUMENT
  PHOTO
  SPREADSHEET
  OTHER
}

enum NotificationType {
  MAINTENANCE_REQUEST
  SHOWING_BOOKED
  LEASE_EXPIRING
  INSPECTION_DUE
  PROSPECT_ASSIGNED
  DOCUMENT_UPLOADED
  ASSIGNMENT_CHANGED
  MESSAGE_RECEIVED
  GENERAL
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  ASSIGNED
  STATUS_CHANGED
  COMMENT_ADDED
  DOCUMENT_UPLOADED
  PHOTO_UPLOADED
  NOTE_ADDED
  MESSAGE_SENT
  LEASE_SIGNED
  TENANT_ASSIGNED
  RENT_CHANGED
  PRIORITY_CHANGED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum PortalMessageType {
  GENERAL
  BILLING
  MAINTENANCE
  LEASE
  NOISE
  OTHER
}

enum PortalMessagePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Auth (NextAuth) ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(OFFICE_STAFF)
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  accounts              Account[]
  sessions              Session[]
  tenantProfile         Tenant?
  prospectProfile       Prospect?
  assignedMaintenance   MaintenanceRequest[] @relation("AssignedStaff")
  createdMaintenance    MaintenanceRequest[] @relation("CreatedBy")
  notes                 Note[]
  activityLogs          ActivityLog[]
  messagesSent          Message[]            @relation("MessagesSent")
  messagesReceived      Message[]            @relation("MessagesReceived")
  notifications         Notification[]
  calendarEvents        CalendarEvent[]      @relation("EventAssignee")
  createdCalendarEvents CalendarEvent[]      @relation("EventCreator")
  showings              Showing[]            @relation("ShowingAgent")
  savedSearches         SavedSearch[]
  auditLogs             AuditLog[]
  paymentsRecorded      Payment[]            @relation("PaymentsRecorded")

  @@index([role])
  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Owners ──────────────────────────────────────────────────────────────────

model Owner {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  properties Property[]
  documents  Document[]

  @@map("owners")
}

// ─── Properties ──────────────────────────────────────────────────────────────

model Property {
  id              String         @id @default(cuid())
  name            String
  addressLine1    String
  addressLine2    String?
  city            String
  state           String
  zipCode         String
  country         String         @default("US")
  status          PropertyStatus @default(ACTIVE)
  ownerId         String?
  squareFootage   Int?
  bedrooms        Int?
  bathrooms       Float?
  rentAmount      Decimal?       @db.Decimal(10, 2)
  securityDeposit Decimal?       @db.Decimal(10, 2)
  utilities       String[]       @default([])
  appliances      String[]       @default([])
  amenities       String[]       @default([])
  parking         String?
  internalNotes   String?        @db.Text
  tags            String[]       @default([])
  /// Overflow AppFolio fields (fees, warranty, description, etc.)
  appfolioExtras  Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  owner              Owner?               @relation(fields: [ownerId], references: [id])
  units              Unit[]
  photos             PropertyPhoto[]
  documents          Document[]
  maintenanceRequests MaintenanceRequest[]
  calendarEvents     CalendarEvent[]
  prospects          ProspectProperty[]
  notes              Note[]
  activityLogs       ActivityLog[]

  @@index([city, state])
  @@index([status])
  @@index([name])
  @@map("properties")
}

model PropertyPhoto {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  caption    String?
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_photos")
}

// ─── Units ───────────────────────────────────────────────────────────────────

model Unit {
  id              String     @id @default(cuid())
  propertyId      String
  unitNumber      String
  status          UnitStatus @default(AVAILABLE)
  squareFootage   Int?
  bedrooms        Int?
  bathrooms       Float?
  rentAmount      Decimal    @db.Decimal(10, 2)
  depositAmount   Decimal?   @db.Decimal(10, 2)
  moveInDate      DateTime?
  moveOutDate     DateTime?
  internalNotes   String?    @db.Text
  /// Overflow AppFolio fields (revenue flag, tags, description, etc.)
  appfolioExtras  Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  property            Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  inspections         Inspection[]
  documents           Document[]
  calendarEvents      CalendarEvent[]
  notes               Note[]
  activityLogs        ActivityLog[]

  @@unique([propertyId, unitNumber])
  @@index([status])
  @@map("units")
}

// ─── Tenants & Leases ────────────────────────────────────────────────────────

model Tenant {
  id        String    @id @default(cuid())
  userId    String    @unique
  phone     String?
  emergencyContact String?
  emergencyPhone   String?
  pets           String?
  internalNotes  String?   @db.Text
  /// Overflow AppFolio fields (tenantType, status, tags, etc.)
  appfolioExtras  Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  leases              Lease[]
  charges             Charge[]
  payments            Payment[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]
  messages            Message[]
  notes               Note[]
  activityLogs        ActivityLog[]

  @@map("tenants")
}

model Lease {
  id              String      @id @default(cuid())
  unitId          String
  tenantId        String
  startDate       DateTime
  endDate         DateTime
  rentAmount      Decimal     @db.Decimal(10, 2)
  depositAmount   Decimal?    @db.Decimal(10, 2)
  status          LeaseStatus @default(ACTIVE)
  terms           String?     @db.Text
  /// Set when staff flags the lease as delinquent (balance overdue).
  delinquentAt    DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  unit     Unit   @relation(fields: [unitId], references: [id])
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  documents Document[]
  charges   Charge[]
  payments  Payment[]

  @@index([status])
  @@index([endDate])
  @@index([delinquentAt])
  @@map("leases")
}

model Charge {
  id          String       @id @default(cuid())
  leaseId     String
  tenantId    String
  type        ChargeType   @default(RENT)
  status      ChargeStatus @default(OPEN)
  amount      Decimal      @db.Decimal(10, 2)
  /// Amount already applied from payments.
  amountPaid  Decimal      @default(0) @db.Decimal(10, 2)
  dueDate     DateTime
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  voidedAt    DateTime?

  lease    Lease     @relation(fields: [leaseId], references: [id])
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payments Payment[]

  @@index([leaseId, status])
  @@index([tenantId, status])
  @@index([dueDate])
  @@map("charges")
}

model Payment {
  id                    String        @id @default(cuid())
  leaseId               String
  tenantId              String
  chargeId              String?
  amount                Decimal       @db.Decimal(10, 2)
  method                PaymentMethod @default(OTHER)
  status                PaymentStatus @default(SUCCEEDED)
  paidAt                DateTime      @default(now())
  reference             String?
  notes                 String?
  stripeCheckoutSessionId String?     @unique
  stripePaymentIntentId   String?     @unique
  recordedById          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  lease      Lease   @relation(fields: [leaseId], references: [id])
  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  charge     Charge? @relation(fields: [chargeId], references: [id])
  recordedBy User?   @relation("PaymentsRecorded", fields: [recordedById], references: [id])

  @@index([leaseId, status])
  @@index([tenantId, status])
  @@index([paidAt])
  @@map("payments")
}

model Inspection {
  id          String   @id @default(cuid())
  unitId      String
  type        String
  date        DateTime
  inspector   String?
  notes       String?  @db.Text
  passed      Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit      Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  documents Document[]

  @@map("inspections")
}

// ─── Maintenance ─────────────────────────────────────────────────────────────

model MaintenanceRequest {
  id               String              @id @default(cuid())
  requestNumber    String              @unique
  propertyId       String
  unitId           String?
  tenantId         String?
  category         MaintenanceCategory
  priority         MaintenancePriority @default(MEDIUM)
  status           MaintenanceStatus   @default(SUBMITTED)
  title            String
  description      String              @db.Text
  assignedStaffId  String?
  createdById      String?
  vendor           String?
  cost             Decimal?            @db.Decimal(10, 2)
  targetCompletion DateTime?
  completedAt      DateTime?
  internalNotes    String?             @db.Text
  tenantNotes      String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?

  property      Property              @relation(fields: [propertyId], references: [id])
  unit          Unit?                 @relation(fields: [unitId], references: [id])
  tenant        Tenant?               @relation(fields: [tenantId], references: [id])
  assignedStaff User?                 @relation("AssignedStaff", fields: [assignedStaffId], references: [id])
  createdBy     User?                 @relation("CreatedBy", fields: [createdById], references: [id])
  photos        MaintenancePhoto[]
  attachments   MaintenanceAttachment[]
  timeline      MaintenanceTimeline[]
  documents     Document[]
  notes         Note[]
  activityLogs  ActivityLog[]
  calendarEvents CalendarEvent[]
  portalMessages Message[]

  @@index([status])
  @@index([priority])
  @@index([propertyId])
  @@index([assignedStaffId])
  @@map("maintenance_requests")
}

model MaintenancePhoto {
  id        String   @id @default(cuid())
  requestId String
  url       String
  caption   String?
  uploadedBy String?
  createdAt DateTime @default(now())

  request MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("maintenance_photos")
}

model MaintenanceAttachment {
  id        String   @id @default(cuid())
  requestId String
  fileName  String
  url       String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())

  request MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("maintenance_attachments")
}

model MaintenanceTimeline {
  id        String   @id @default(cuid())
  requestId String
  userId    String?
  action    String
  oldValue  String?
  newValue  String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  request MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("maintenance_timeline")
}

// ─── Prospects & CRM ─────────────────────────────────────────────────────────

model Prospect {
  id          String         @id @default(cuid())
  userId      String?        @unique
  name        String
  email       String
  phone       String?
  leadSource  String?
  budget      Decimal?       @db.Decimal(10, 2)
  moveDate    DateTime?
  pets            String?
  internalNotes   String?        @db.Text
  status          ProspectStatus @default(NEW)
  assignedAgentId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  user       User?              @relation(fields: [userId], references: [id])
  properties ProspectProperty[]
  showings   Showing[]
  timeline   ProspectTimeline[]
  documents  Document[]
  notes      Note[]
  activityLogs ActivityLog[]

  @@index([status])
  @@index([email])
  @@map("prospects")
}

model ProspectProperty {
  id         String   @id @default(cuid())
  prospectId String
  propertyId String
  createdAt  DateTime @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([prospectId, propertyId])
  @@map("prospect_properties")
}

model ProspectTimeline {
  id         String   @id @default(cuid())
  prospectId String
  userId     String?
  action     String
  oldValue   String?
  newValue   String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@map("prospect_timeline")
}

model Showing {
  id          String        @id @default(cuid())
  prospectId  String
  propertyId  String?
  unitId      String?
  agentId     String
  scheduledAt DateTime
  duration    Int           @default(30)
  status      ShowingStatus @default(SCHEDULED)
  notes       String?       @db.Text
  attended    Boolean?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  agent    User     @relation("ShowingAgent", fields: [agentId], references: [id])

  @@index([scheduledAt])
  @@index([agentId])
  @@map("showings")
}

// ─── Calendar ────────────────────────────────────────────────────────────────

model CalendarEvent {
  id                  String            @id @default(cuid())
  title               String
  type                CalendarEventType
  propertyId          String?
  unitId              String?
  maintenanceRequestId String?
  assigneeId          String?
  createdById         String?
  startAt             DateTime
  endAt               DateTime
  allDay              Boolean           @default(false)
  color               String?
  notes               String?           @db.Text
  recurrence          RecurrenceType    @default(NONE)
  recurrenceEnd       DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  property           Property?           @relation(fields: [propertyId], references: [id])
  unit               Unit?               @relation(fields: [unitId], references: [id])
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])
  assignee           User?               @relation("EventAssignee", fields: [assigneeId], references: [id])
  createdBy          User?               @relation("EventCreator", fields: [createdById], references: [id])

  @@index([startAt, endAt])
  @@index([type])
  @@map("calendar_events")
}

// ─── Documents ───────────────────────────────────────────────────────────────

model Document {
  id                   String       @id @default(cuid())
  name                 String
  fileName             String
  url                  String
  mimeType             String?
  size                 Int?
  type                 DocumentType @default(OTHER)
  propertyId           String?
  unitId               String?
  tenantId             String?
  ownerId              String?
  prospectId           String?
  maintenanceRequestId String?
  leaseId              String?
  inspectionId         String?
  uploadedById         String?
  tags                 String[]     @default([])
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?

  property           Property?           @relation(fields: [propertyId], references: [id])
  unit               Unit?               @relation(fields: [unitId], references: [id])
  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  owner              Owner?              @relation(fields: [ownerId], references: [id])
  prospect           Prospect?           @relation(fields: [prospectId], references: [id])
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])
  lease              Lease?              @relation(fields: [leaseId], references: [id])
  inspection         Inspection?         @relation(fields: [inspectionId], references: [id])

  @@index([name])
  @@index([type])
  @@map("documents")
}

// ─── Notes ───────────────────────────────────────────────────────────────────

model Note {
  id                   String    @id @default(cuid())
  content              String    @db.Text
  authorId             String
  propertyId           String?
  unitId               String?
  tenantId             String?
  prospectId           String?
  maintenanceRequestId String?
  mentions             String[]  @default([])
  isPinned             Boolean   @default(false)
  editHistory          Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  author             User                @relation(fields: [authorId], references: [id])
  property           Property?           @relation(fields: [propertyId], references: [id])
  unit               Unit?               @relation(fields: [unitId], references: [id])
  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  prospect           Prospect?           @relation(fields: [prospectId], references: [id])
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])
  attachments        NoteAttachment[]

  @@index([authorId])
  @@map("notes")
}

model NoteAttachment {
  id       String @id @default(cuid())
  noteId   String
  fileName String
  url      String
  mimeType String?
  size     Int?

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@map("note_attachments")
}

// ─── Messages ────────────────────────────────────────────────────────────────

model Message {
  id            String                 @id @default(cuid())
  senderId      String
  receiverId    String
  tenantId      String?
  subject       String?
  body          String                 @db.Text
  /// Tenant portal contact category (null = legacy / staff SMS note).
  type          PortalMessageType?
  priority      PortalMessagePriority?
  callbackPhone String?
  status        MessageStatus          @default(SENT)
  /// Staff claimed this portal message and is actively working it.
  agentWorking  Boolean                @default(false)
  /// Root message id for threaded portal conversations (null on the root itself).
  threadId      String?
  parentMessageId String?
  /// Linked work order created from this portal thread (usually set on the root).
  maintenanceRequestId String?
  readAt        DateTime?
  createdAt     DateTime               @default(now())
  deletedAt     DateTime?

  sender   User    @relation("MessagesSent", fields: [senderId], references: [id])
  receiver User    @relation("MessagesReceived", fields: [receiverId], references: [id])
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  parentMessage Message?  @relation("MessageReplies", fields: [parentMessageId], references: [id])
  replies       Message[] @relation("MessageReplies")
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])

  @@index([senderId, receiverId])
  @@index([tenantId, status])
  @@index([createdAt])
  @@index([threadId, createdAt])
  @@index([maintenanceRequestId])
  @@map("messages")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Activity & Audit ────────────────────────────────────────────────────────

model ActivityLog {
  id                   String         @id @default(cuid())
  action               ActivityAction
  entityType           String
  entityId             String
  userId               String?
  propertyId           String?
  unitId               String?
  tenantId             String?
  prospectId           String?
  maintenanceRequestId String?
  fieldName            String?
  oldValue             String?        @db.Text
  newValue             String?        @db.Text
  metadata             Json?
  createdAt            DateTime       @default(now())

  user               User?               @relation(fields: [userId], references: [id])
  property           Property?           @relation(fields: [propertyId], references: [id])
  unit               Unit?               @relation(fields: [unitId], references: [id])
  tenant             Tenant?             @relation(fields: [tenantId], references: [id])
  prospect           Prospect?           @relation(fields: [prospectId], references: [id])
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])

  @@index([entityType, entityId])
  @@index([propertyId])
  @@index([createdAt])
  @@map("activity_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Search & Settings ───────────────────────────────────────────────────────

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     String
  filters   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
